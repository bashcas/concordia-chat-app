# =============================================================================
# Concordia – local development environment
# =============================================================================
# Copy this file and fill in any values you want to override:
#
#   cp infra/.env.example infra/.env
#
# All defaults work for local development out of the box.
# docker-compose reads infra/.env automatically when run from the infra/ dir,
# or pass it explicitly:
#   docker-compose --env-file infra/.env -f infra/docker-compose.yml up
#
# IMPORTANT: infra/.env is git-ignored. Never commit real secrets.
# =============================================================================


# ── Security pattern flags (deploy-time) ──────────────────────────────────────
# Toggle architectural patterns for lab demos. Restart the stack after changes.
# Start the stack with:  ./infra/up.sh --build
# Inspect resolved mode: ./infra/up.sh --print
#
# Invalid combination (up.sh will refuse to start):
#   SECURITY_REVERSE_PROXY=false + SECURITY_NETWORK_SEGMENTATION=true
#   (the gateway is not published on the host when segmentation is on)
#
# SECURITY_REVERSE_PROXY=true   — Nginx edge on :443/:8088; browser uses /api
# SECURITY_REVERSE_PROXY=false  — gateway :8080 and web-app :3000 on the host
# SECURITY_NETWORK_SEGMENTATION=true  — private-net is internal (default)
# SECURITY_NETWORK_SEGMENTATION=false — private-net reachable from host (debug)
# SECURITY_AUDIT_TRAIL=true     — audit + audit-db consume audit.events
# SECURITY_AUDIT_TRAIL=false    — no consumer/DB; producers still emit to Kafka
# SECURITY_SECURE_CHANNEL=true  — TLS at Nginx :443 (trust infra/certs/ca.crt)
# SECURITY_SECURE_CHANNEL=false — plain HTTP at :8088 (with reverse proxy on)
#
# Derived by infra/up.sh (do not set manually unless using raw docker compose):
#   COMPOSE_PROFILES, GATEWAY_TLS_ENABLED, GATEWAY_ALLOWED_ORIGINS,
#   NEXT_PUBLIC_API_URL, SECURITY_SECURE_CHANNEL (passed to reverse-proxy)
#
# Direct mode (REVERSE_PROXY=false) includes http://localhost:3000 in
# GATEWAY_ALLOWED_ORIGINS so the browser can call the gateway from the web app.
#
SECURITY_REVERSE_PROXY=true
SECURITY_NETWORK_SEGMENTATION=true
SECURITY_AUDIT_TRAIL=true
SECURITY_SECURE_CHANNEL=true

# ── Scaling pattern flags (Lab 7) ─────────────────────────────────────────────
# Horizontal scaling toggles read by the perf harness (tests/perf/run_login_test.sh).
# They do NOT affect ./infra/up.sh. Two independent flags → a 2x2 topology matrix;
# flip either and re-run the perf script to compare throughput with vs without
# that load balancer (the client always hits localhost:8080). See
# docs/gateway-load-balancing.md.
#
# SCALING_GATEWAY_LB
#   false — single gateway instance (baseline, no gateway LB)
#   true  — 3 gateway replicas (gateway, gateway_2, gateway_3) behind gateway-lb
#           (Nginx least_conn), via infra/docker-compose.gateway-scale.yml
# SCALING_AUTH_LB
#   false — single auth instance; gateway calls auth_1 directly (no auth LB)
#   true  — 3 auth replicas (auth_1/2/3) behind auth-lb (Nginx least_conn)
SCALING_GATEWAY_LB=false
SCALING_AUTH_LB=false

# Active compose profiles when using raw docker compose (up.sh overrides this):
COMPOSE_PROFILES=reverse-proxy,audit-trail

# ── Security ──────────────────────────────────────────────────────────────────

# HS256 JWT signing secret shared by every service that validates tokens.
# Must be at least 32 characters (256 bits).
# !! CHANGE THIS before deploying to any non-local environment !!
JWT_SECRET=changeme-32-byte-dev-secret!!!!!!!!!!


# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Single Postgres instance (port 5432) shared by auth, servers, and tips.
# Each service connects to its own database created by infra/postgres/init.sql:
#   auth    → auth_db     (SPRING_DATASOURCE_URL in compose)
#   servers → servers_db  (SPRING_DATASOURCE_URL in compose)
#   tips    → tips_db     (DATABASE_URL in compose)

POSTGRES_USER=discord
POSTGRES_PASSWORD=discord

# Host-side access (psql, DBeaver, TablePlus, etc.):
#   host=localhost  port=5432  user=$POSTGRES_USER  password=$POSTGRES_PASSWORD


# ── Cassandra ─────────────────────────────────────────────────────────────────
# Single-node Cassandra instance (port 9042) used by Chat.
# The discord_chat keyspace is created by infra/cassandra/init.cql on first start.
# No credentials are configured (open access for local dev).

CASSANDRA_HOST=cassandra      # Docker service name — used by chat inside the network
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=discord_chat


# ── Redis ─────────────────────────────────────────────────────────────────────
# Redis instance (port 6379) used by Voice (signaling) and Presence (sessions).
# No password configured for local dev.

REDIS_ADDR=redis://redis:6379  # Used by voice and presence inside Docker
# Host-side: redis-cli -h localhost -p 6379


# ── MinIO (S3-compatible object storage) ──────────────────────────────────────
# Used by Chat for file/image attachments. Bucket "attachments" is created
# automatically by minio-init on first start.
# Web console: http://localhost:9001  |  S3 API: http://localhost:9000

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=attachments
# Internal S3 endpoint used by Chat inside Docker: http://minio:9000


# ── Kafka ─────────────────────────────────────────────────────────────────────
# Topics created automatically on first start (by kafka-init):
#   user-registered  │ producer: auth                       → consumer: servers
#   message-created  │ producer: chat
#   mention          │ producer: chat
#   audit.events     │ producer: auth/servers/chat/voice/gw  → consumer: audit
#
# Kafka is on the internal network only (listener kafka:9093). There is no
# host-reachable listener since Network Segmentation.


# ── Audit Trail (Pattern 3) ───────────────────────────────────────────────────
# Credentials for the append-only audit log store (audit-db).
AUDIT_DB_SUPERUSER=audit_admin
AUDIT_DB_SUPERUSER_PASSWORD=audit_admin
AUDIT_WRITER_PASSWORD=audit_writer
AUDIT_READER_PASSWORD=audit_reader


# ── Service ports ─────────────────────────────────────────────────────────────
# Change a value if the default port conflicts with something on your machine.
# The published host port in docker-compose follows the value set here.
#
# Note: AUTH_PORT (8081) and SERVERS_PORT (8082) are fixed in
#   services/auth/src/main/resources/application.properties and
#   services/servers/src/main/resources/application.properties.
#   Overriding them requires rebuilding those images.

GATEWAY_PORT=8080
CHAT_PORT=8083
VOICE_PORT=8084
TIPS_PORT=8085
PRESENCE_PORT=8086
GRPC_PORT=50051


# ── Web App ───────────────────────────────────────────────────────────────────
# Base URL the browser uses to reach the Gateway API.
#
# Since the Reverse Proxy pattern, the browser only ever talks to the reverse
# proxy at https://localhost. API calls go under the /api prefix; the proxy
# strips /api and forwards to the gateway. WebSockets travel the same prefix.
NEXT_PUBLIC_API_URL=/api
