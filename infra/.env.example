# Copy this file to infra/.env and fill in values before running docker-compose.
# cp infra/.env.example infra/.env

# ── Shared ──────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production

# ── PostgreSQL (Auth + Servers + Tips) ──────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=concordia
POSTGRES_PASSWORD=concordia
POSTGRES_DB=concordia

# ── Cassandra (Chat) ────────────────────────────────────────────
CASSANDRA_HOSTS=cassandra
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=discord_chat

# ── Redis (Voice + Presence) ────────────────────────────────────
REDIS_ADDR=redis:6379

# ── MinIO (Chat attachments) ────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=attachments

# ── Kafka ───────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# ── Service ports ───────────────────────────────────────────────
GATEWAY_PORT=8080
AUTH_PORT=8081
SERVERS_PORT=8082
CHAT_PORT=8083
VOICE_PORT=8084
TIPS_PORT=8085
PRESENCE_PORT=8086
GRPC_PORT=50051

# ── Frontend ────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
