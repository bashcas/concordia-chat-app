# =============================================================================
# Concordia – local development environment
# =============================================================================
# Copy this file and fill in any values you want to override:
#
#   cp infra/.env.example infra/.env
#
# All defaults work for local development out of the box.
# docker-compose reads infra/.env automatically when run from the infra/ dir,
# or pass it explicitly:
#   docker-compose --env-file infra/.env -f infra/docker-compose.yml up
#
# IMPORTANT: infra/.env is git-ignored. Never commit real secrets.
# =============================================================================


# ── Security ──────────────────────────────────────────────────────────────────

# HS256 JWT signing secret shared by every service that validates tokens.
# Must be at least 32 characters (256 bits).
# !! CHANGE THIS before deploying to any non-local environment !!
JWT_SECRET=changeme-32-byte-dev-secret!!!!!!!!!!


# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Single Postgres instance (port 5432) shared by auth, servers, and tips.
# Each service connects to its own database created by infra/postgres/init.sql:
#   auth    → auth_db     (SPRING_DATASOURCE_URL in compose)
#   servers → servers_db  (SPRING_DATASOURCE_URL in compose)
#   tips    → tips_db     (DATABASE_URL in compose)

POSTGRES_USER=discord
POSTGRES_PASSWORD=discord

# Host-side access (psql, DBeaver, TablePlus, etc.):
#   host=localhost  port=5432  user=$POSTGRES_USER  password=$POSTGRES_PASSWORD


# ── Cassandra ─────────────────────────────────────────────────────────────────
# Single-node Cassandra instance (port 9042) used by Chat.
# The discord_chat keyspace is created by infra/cassandra/init.cql on first start.
# No credentials are configured (open access for local dev).

CASSANDRA_HOST=cassandra      # Docker service name — used by chat inside the network
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=discord_chat


# ── Redis ─────────────────────────────────────────────────────────────────────
# Redis instance (port 6379) used by Voice (signaling) and Presence (sessions).
# No password configured for local dev.

REDIS_ADDR=redis://redis:6379  # Used by voice and presence inside Docker
# Host-side: redis-cli -h localhost -p 6379


# ── MinIO (S3-compatible object storage) ──────────────────────────────────────
# Used by Chat for file/image attachments. Bucket "attachments" is created
# automatically by minio-init on first start.
# Web console: http://localhost:9001  |  S3 API: http://localhost:9000

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=attachments
# Internal S3 endpoint used by Chat inside Docker: http://minio:9000


# ── Kafka ─────────────────────────────────────────────────────────────────────
# Topics created automatically on first start (by kafka-init):
#   user-registered  │ producer: auth    → consumer: servers
#   message-created  │ producer: chat
#   mention          │ producer: chat

# Host-side bootstrap address — for kafka-console-consumer, kcat, etc.
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Services inside Docker use the INTERNAL listener (hardcoded in docker-compose):
#   KAFKA_BROKERS=kafka:9093
# Do not override KAFKA_BROKERS here; it is not read from .env by compose.


# ── Service ports ─────────────────────────────────────────────────────────────
# Change a value if the default port conflicts with something on your machine.
# The published host port in docker-compose follows the value set here.
#
# Note: AUTH_PORT (8081) and SERVERS_PORT (8082) are fixed in
#   services/auth/src/main/resources/application.properties and
#   services/servers/src/main/resources/application.properties.
#   Overriding them requires rebuilding those images.

GATEWAY_PORT=8080
CHAT_PORT=8083
VOICE_PORT=8084
TIPS_PORT=8085
PRESENCE_PORT=8086
GRPC_PORT=50051


# ── Web App ───────────────────────────────────────────────────────────────────
# Base URL the Next.js app uses to reach the Gateway API.
#
# The default (http://gateway:8080) works for server-side rendering inside Docker.
# For client-side (browser) API calls, NEXT_PUBLIC_* vars are baked into the
# bundle at build time — "gateway" is not resolvable from the browser.
# Override to http://localhost:8080 if your app makes direct browser → API calls:
#   NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_API_URL=http://gateway:8080
